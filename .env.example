# ─────────────────────────────────────────────
# Gold Asset Manager — Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=gold_aset
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti_password_anda_disini

# JWT Secret — gunakan string panjang yang acak
JWT_SECRET=ganti_dengan_secret_panjang_dan_random

# (Opsional) Jika ingin override URL API frontend saat build
# Biarkan kosong jika menggunakan nginx proxy (Docker)
VITE_API_URL=
